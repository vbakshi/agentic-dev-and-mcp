# Required
OPENAI_API_KEY=sk-proj-your-key-here

# SendGrid (required unless SALES_WORKFLOW_DRY_RUN=true)
SENDGRID_API_KEY=your-sendgrid-api-key
SALES_FROM_EMAIL=you@example.com
SALES_TO_EMAIL=prospect@example.com

# Optional
SALES_AGENT_MODEL=gpt-4o-mini
SALES_WORKFLOW_DRY_RUN=false

# Other provider keys (optional)
ANTHROPIC_API_KEY=sk-ant-your-key-here
GOOGLE_API_KEY=your-google-api-key
DEEPSEEK_API_KEY=your-deepseek-key
GROQ_API_KEY=your-groq-key

# Pushover notifications (optional, for other workflows)
PUSHOVER_USER=your-pushover-user-key
PUSHOVER_TOKEN=your-pushover-app-token
